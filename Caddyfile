# ============================================
# Caddyfile — Master Reverse Proxy
# ============================================
# This runs on the HOST (not in Docker).
# Install: sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
#          curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
#          curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list
#          sudo apt update && sudo apt install caddy
#
# Before enabling Caddy:
#   1. Stop the existing robionix_nginx container (it owns 80/443)
#   2. sudo systemctl enable --now caddy
#   3. Re-route robionix through Caddy as shown below

# ─── MagicQC Webmail + JMAP API ──────────────
# mail.magicqc.online serves both the Next.js webmail
# and the Stalwart JMAP/auth/upload/download/DAV APIs.
# JMAP-related paths go to Stalwart; everything else to webmail.
mail.magicqc.online {
	# JMAP session discovery
	handle /.well-known/jmap {
		reverse_proxy localhost:18080
	}

	# JMAP API endpoint
	handle /jmap* {
		reverse_proxy localhost:18080
	}

	# Authentication endpoints
	handle /auth/* {
		reverse_proxy localhost:18080
	}
	handle /api/* {
		reverse_proxy localhost:18080
	}

	# Blob upload / download
	handle /upload/* {
		reverse_proxy localhost:18080
	}
	handle /download/* {
		reverse_proxy localhost:18080
	}

	# EventSource (push notifications)
	handle /eventsource* {
		reverse_proxy localhost:18080
	}

	# CalDAV / CardDAV / WebDAV
	handle /dav/* {
		reverse_proxy localhost:18080
	}
	handle /.well-known/caldav {
		reverse_proxy localhost:18080
	}
	handle /.well-known/carddav {
		reverse_proxy localhost:18080
	}

	# Autoconfig for desktop clients
	handle /mail/config-v1.1.xml {
		reverse_proxy localhost:18080
	}

	# Everything else → Next.js webmail
	handle {
		reverse_proxy localhost:13000
	}
}

# ─── Stalwart JMAP API (dedicated subdomain) ─
# Alternative direct access for API clients
jmap.magicqc.online {
	reverse_proxy localhost:18080
}

# ─── Stalwart Admin Panel ────────────────────
# Restrict to admin use only
admin.magicqc.online {
	reverse_proxy localhost:18080
}

# ─── MTA-STS Policy ─────────────────────────
# Required for MTA-STS (mail transport security)
mta-sts.magicqc.online {
	header Content-Type text/plain
	respond /\.well-known/mta-sts.txt "version: STSv1
mode: enforce
mx: mail.magicqc.online
max_age: 604800
"
}

# ─── Autoconfig / Autodiscover ───────────────
# Thunderbird / Outlook autodiscovery
autoconfig.magicqc.online {
	reverse_proxy localhost:18080
}
autodiscover.magicqc.online {
	reverse_proxy localhost:18080
}

# ─── MagicQC Main Site (Laravel) ─────────────
magicqc.online, www.magicqc.online {
	# Laravel runs in Docker via magicqc_nginx on port 8081
	reverse_proxy localhost:8081
}

# ─── Robionix (WordPress) ────────────────────
# Previously owned ports 80/443 via robionix_nginx.
# Now Caddy handles TLS and proxies to the WordPress container.
robionix.com, www.robionix.com {
	reverse_proxy localhost:8080
}
