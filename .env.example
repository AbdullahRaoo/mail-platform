# ============================================
# MagicQC Mail Platform — Environment Variables
# ============================================
# NEVER commit this file to Git!
# Copy .env.example to .env and fill in values.

# ─── Domain Configuration ─────────────────────
MAIL_HOSTNAME=mail.magicqc.online
MAIL_DOMAIN=magicqc.online

# ─── Next.js Webmail ──────────────────────────
# Public URL for the JMAP API (the browser hits this)
NEXT_PUBLIC_JMAP_URL=https://mail.magicqc.online
# Internal URL for server-side JMAP calls (container-to-container)
JMAP_INTERNAL_URL=http://stalwart:8080

# ─── Stalwart Admin ──────────────────────────
# Set on first run — this becomes the superadmin password
# Change it IMMEDIATELY after first login
STALWART_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ─── Backup (optional — Restic to S3/B2) ─────
# RESTIC_REPOSITORY=s3:s3.amazonaws.com/magicqc-backups/mail
# RESTIC_PASSWORD=your-strong-restic-password
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
